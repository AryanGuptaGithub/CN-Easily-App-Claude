

<nav class="navbar">
  <div class="nav-container">

    <a href="/" class="nav-brand">
      💼 Job<span>Portal</span>
    </a>


    <div class="nav-search">
      <form action="/jobs" method="GET">
        <input
          type="text"
          name="search"
          placeholder="Search jobs, companies, skills..."
          value="<%= typeof search !== 'undefined' ? search : '' %>"
        />
        <button type="submit" class="btn btn-primary btn-sm">🔍</button>
      </form>
    </div>


    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/jobs">Browse Jobs</a>

      <% if (currentUser) { %>
   
        <a href="/jobs/new" class="btn-nav-primary btn">+ Post Job</a>
        <a href="/my-jobs">My Jobs</a>

        <span class="nav-user-name">👤 <%= currentUser.name %></span>

        <form action="/logout" method="POST" style="margin: 0;">
          <button type="submit" class="btn-nav-outline btn btn-sm">Logout</button>
        </form>

      <% } else { %>
    
        <a href="/login" class="btn-nav-outline btn">Login</a>
        <a href="/register" class="btn-nav-primary btn">Register</a>
      <% } %>
    </div>


    <button class="hamburger" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</nav>
