
<% if (successMsg || errorMsg) { %>
  <div class="flash-container">
    <div class="container">

      <% if (successMsg) { %>
        <div class="flash flash-success">
          <span>✅</span>
          <span><%= successMsg %></span>
          <button class="flash-close" aria-label="Close">✕</button>
        </div>
      <% } %>

      <% if (errorMsg) { %>
        <div class="flash flash-error">
          <span>❌</span>
          <span><%= errorMsg %></span>
          <button class="flash-close" aria-label="Close">✕</button>
        </div>
      <% } %>

    </div>
  </div>
<% } %>
